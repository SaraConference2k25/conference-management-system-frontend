# ===================================
# SARA Conference 2025 - Frontend Configuration
# ===================================

# ===================================
# Backend API Configuration
# ===================================
# The base URL for the Spring Boot backend API
# Development: http://localhost:8080/api
# Production: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ===================================
# Application Configuration
# ===================================
NEXT_PUBLIC_APP_NAME=SARA Conference 2025
NEXT_PUBLIC_APP_VERSION=1.0.0

# ===================================
# Feature Flags (Optional)
# ===================================
# Enable/disable dark mode support
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Enable/disable analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ===================================
# Development Configuration (Optional)
# ===================================
# Enable debug logging
# NEXT_PUBLIC_DEBUG=false

# API request timeout in milliseconds
# NEXT_PUBLIC_API_TIMEOUT=30000

# ===================================
# Production Configuration
# ===================================
# When deploying to production, update these values:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
# NEXT_PUBLIC_APP_ENV=production
# NODE_ENV=production
